{
  "manifest_version": 3,
  "name": "AIToolbox",
  "version": "3.3.3",
  "description": "Independently adjust chat width for Gemini, Claude, and ChatGPT. Export conversations as Markdown or PDF. Toggle code auto-wrap.",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "*://gemini.google.com/*",
    "*://claude.ai/*",
    "*://chatgpt.com/*",
    "*://chat.openai.com/*"
  ],
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://gemini.google.com/*",
        "*://claude.ai/*",
        "*://chatgpt.com/*",
        "*://chat.openai.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    }
  ]
}
